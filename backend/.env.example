APP_NAME=Medical Checkup Agent
APP_ENV=development

# 默认使用 SQLite。切到 MySQL 时，把下面这一行改成：
# DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/medical_agent?charset=utf8mb4
DATABASE_URL=sqlite:///../data/sqlite/medical_agent.db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800
REPORT_QUEUE_POLL_INTERVAL_SECONDS=1.0
REPORT_QUEUE_LEASE_SECONDS=300
UPLOAD_DIR=../data/uploads
OUTPUT_DIR=../data/output
QWEN_API_KEY=replace-me
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen3.5-plus
QWEN_FAST_MODEL=qwen3.5-flash
QWEN_MAX_MODEL=qwen3-max
QWEN_VL_MODEL=qwen3-vl-flash
SHORT_TERM_CONTEXT_TURNS=4
AGENT_RESPONSE_CACHE_TTL_SECONDS=1800

# 不配置 REDIS_URL 时，缓存会自动退回数据库表。
# REDIS_URL=redis://127.0.0.1:6379/0
REDIS_CACHE_TTL_SECONDS=1800
REDIS_KEY_PREFIX=medical_agent

# development / test / local 默认自动建表。
# 生产环境建议显式设为 false，并在部署前先执行 `alembic upgrade head`。
# DB_AUTO_INIT_SCHEMA=false

WHO_ENABLED=true
WHO_TIMEOUT_SECONDS=6
WHO_CONNECT_TIMEOUT_SECONDS=3
WHO_TRUST_ENV=false
WHO_CLIENT_ID=replace-me
WHO_CLIENT_SECRET=replace-me
